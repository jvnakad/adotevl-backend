{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["<rootDir>/node_modules/ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.json"
    }]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
